---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Breaking Accelerator | Coaching pour Breakers Professionnels',
  description = 'Breaking Accelerator est le premier programme d\'accompagnement conçu pour les breakers qui veulent transformer leur niveau artistique en revenu stable.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Icons -->
  <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

  <style is:global>
    body {
      font-family: 'Manrope', sans-serif;
      background-color: #F5F3EF;
      color: #1C1C1C;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: 'DM Serif Display', serif;
    }
    .marquee-container {
      mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    }
    @keyframes scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-scroll {
      animation: scroll 30s linear infinite;
    }
    .testimonial-marquee {
      mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    }
    @keyframes testimonial-scroll {
      0% { transform: translateX(var(--manual-offset, 0px)); }
      100% { transform: translateX(calc(-50% + var(--manual-offset, 0px))); }
    }
    .testimonial-scroll {
      animation: testimonial-scroll 7s linear infinite;
    }
    @media (min-width: 768px) {
      .testimonial-scroll {
        animation-duration: 70s;
      }
    }
    .testimonial-scroll:hover {
      animation-play-state: paused;
    }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #F5F3EF; }
    ::-webkit-scrollbar-thumb { background: #D1CEC7; border-radius: 3px; }
  </style>
</head>
<body class="antialiased selection:bg-stone-800 selection:text-white overflow-x-hidden">
  <slot />
</body>
</html>
