---
import Layout from '../layouts/Layout.astro';

const LP_URL = '/lp-a';
const R2_BASE = 'https://pub-082a1b16b2b048e9ace33389cff3fac5.r2.dev';
---

<Layout title="Breaking Accelerator | L'accompagnement pour construire une carrière dans le breaking" description="Bboy Junior accompagne les breakers qui ont choisi de faire de leur art un vrai métier. Clarté, connaissance, mindset.">

  <!-- BANNER -->
  <div class="bg-[#1C1C1C] text-[#F5F3EF] text-xs font-bold py-3 text-center tracking-widest uppercase px-4">
    Quand la passion devient une carrière
  </div>

  <!-- NAV -->
  <nav class="sticky top-0 z-50 w-full px-6 py-5 flex justify-between items-center bg-[#F5F3EF]/90 backdrop-blur-sm border-b border-stone-200/50">
    <a href="/" class="text-xl md:text-2xl tracking-tight text-stone-900 leading-none" style="font-family: 'DM Serif Display', serif;">
      Breaking Accelerator
    </a>
    <div class="hidden md:flex items-center space-x-8 text-sm font-medium tracking-wide text-stone-600">
      <a href="/" class="hover:text-stone-900 transition-colors">Accueil</a>
      <a href="/a-propos" class="hover:text-stone-900 transition-colors">À propos</a>
      <a href="/journal" class="hover:text-stone-900 transition-colors">Le Journal</a>
      <a href={LP_URL} class="hover:text-stone-900 transition-colors">Rejoindre</a>
    </div>
    <button id="menu-toggle" class="md:hidden text-2xl">
      <iconify-icon icon="solar:hamburger-menu-linear" stroke-width="1.5"></iconify-icon>
    </button>
  </nav>

  <!-- MOBILE MENU -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-40 bg-[#F5F3EF] flex flex-col items-center justify-center space-y-8 text-2xl font-medium text-stone-900">
    <button id="menu-close" class="absolute top-6 right-6 text-3xl">
      <iconify-icon icon="solar:close-linear" stroke-width="1.5"></iconify-icon>
    </button>
    <a href="/" class="hover:text-stone-500 transition-colors">Accueil</a>
    <a href="/a-propos" class="hover:text-stone-500 transition-colors">À propos</a>
    <a href="/journal" class="hover:text-stone-500 transition-colors">Le Journal</a>
    <a href={LP_URL} class="hover:text-stone-500 transition-colors">Rejoindre</a>
  </div>

  <!-- HERO -->
  <header class="relative w-full h-screen flex flex-col items-center justify-center text-center px-6 overflow-hidden">
    <video autoplay loop muted playsinline poster={`${R2_BASE}/hero-ba-poster.jpg`} class="absolute inset-0 w-full h-full object-cover">
      <source src={`${R2_BASE}/hero-ba.mp4`} type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative z-10 max-w-4xl mx-auto space-y-8">
      <h1 class="text-4xl md:text-5xl lg:text-6xl text-white leading-[1.05] tracking-tight">
        Bâtir sa carrière<br />
        professionnelle dans le breaking<br />
        <span class="italic font-light text-stone-300">avec méthode et ambition</span>
      </h1>
      <p class="max-w-xl mx-auto text-lg md:text-xl text-stone-300 font-light leading-relaxed mt-6">
        Bboy Junior accompagne les breakers qui ont choisi de faire de leur art un vrai métier
      </p>
      <div class="mt-12 flex justify-center">
        <a href="#accroche" class="flex flex-col items-center gap-2 text-stone-400 hover:text-white transition-colors text-sm font-medium tracking-wide">
          Découvrir
          <iconify-icon icon="solar:arrow-down-linear" stroke-width="1.5" class="text-xl animate-bounce"></iconify-icon>
        </a>
      </div>
    </div>
  </header>

  <!-- TICKER -->
  <section class="border-y border-stone-300 py-4 bg-[#EBE8E0] overflow-hidden">
    <div class="marquee-container w-full whitespace-nowrap overflow-hidden">
      <div class="animate-scroll inline-block">
        {['BREAKING', 'EXCELLENCE', 'TRANSMISSION', 'SCÈNE', 'MÉTIER', 'LÉGITIMITÉ', 'DISCIPLINE', 'RECONNAISSANCE',
          'BREAKING', 'EXCELLENCE', 'TRANSMISSION', 'SCÈNE', 'MÉTIER', 'LÉGITIMITÉ', 'DISCIPLINE', 'RECONNAISSANCE'].map((word) => (
          <>
            <span class="text-2xl md:text-4xl px-8 text-stone-400" style="font-family: 'DM Serif Display', serif;">•</span>
            <span class="text-sm md:text-base font-medium tracking-widest uppercase text-stone-800">{word}</span>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ACCROCHE -->
  <section id="accroche" class="py-24 px-6 md:px-12 bg-[#F5F3EF]">
    <div class="max-w-4xl mx-auto text-center space-y-8">
      <h2 class="text-3xl md:text-5xl text-stone-900 leading-tight tracking-tight">
        <span class="text-2xl md:text-3xl">25 ans de carrière internationale. BC One All-Star. Porteur de la flamme olympique. Vainqueur d'Incroyable Talent. Guinness World Record. Conférencier à l'UNESCO.<br />
        <span class="italic text-stone-500">Dans Breaking Accelerator, Bboy Junior vous accompagne personnellement</span></span>
      </h2>
      <div class="w-24 h-px bg-stone-300 mx-auto"></div>
    </div>
  </section>

  <!-- 3 PILIERS -->
  <section class="py-20 px-6 md:px-12 border-t border-stone-200">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            title: 'Clarté',
            body: 'Plus de tâtonnements, une direction précise pour construire ta carrière.',
          },
          {
            title: 'Connaissance',
            body: 'Les informations concrètes du terrain : ce qui fonctionne vraiment pour vivre du breaking aujourd\'hui.',
          },
          {
            title: 'Mindset',
            body: 'Oser passer à l\'action, développer la posture et la confiance d\'un professionnel.',
          },
        ].map(({ title, body }) => (
          <div class="group bg-[#EBE8E0] p-8 md:p-10 rounded-2xl hover:bg-[#E5E1D8] transition-colors duration-300 flex flex-col h-full">
            <h4 class="text-3xl text-stone-900 mb-4 tracking-tight">{title}</h4>
            <p class="text-stone-600 leading-relaxed flex-grow">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CITATION -->
  <section class="py-24 px-6 md:px-12 bg-[#F5F3EF]">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-4xl md:text-6xl text-stone-900 tracking-tight" style="font-family: 'DM Serif Display', serif;">
        "Each one, teach one."
      </p>
      <div class="mt-10 pt-8 border-t border-stone-300/60">
        <p class="text-stone-500 text-sm tracking-widest uppercase font-medium">La philosophie de Bboy Junior</p>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="py-20 bg-[#EBE8E0] border-t border-stone-200">
    <div class="mb-12 text-center">
      <span class="text-xs text-stone-500 uppercase tracking-widest font-medium">Ils ont fait le chemin</span>
    </div>
    <div class="relative">
      <button id="testimonial-prev" class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-[#F5F3EF] border border-stone-300 rounded-full flex items-center justify-center hover:bg-stone-300 transition-colors text-stone-500 hover:text-stone-800 shadow-sm">
        <iconify-icon icon="solar:arrow-left-linear" stroke-width="1.5"></iconify-icon>
      </button>
      <button id="testimonial-next" class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-[#F5F3EF] border border-stone-300 rounded-full flex items-center justify-center hover:bg-stone-300 transition-colors text-stone-500 hover:text-stone-800 shadow-sm">
        <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5"></iconify-icon>
      </button>
    <div class="testimonial-marquee overflow-hidden">
      <div id="testimonial-track" class="testimonial-scroll flex">
        {[...Array(2)].flatMap(() => [
          { quote: "L'accompagnement ainsi que le contenu de Breaking Accelerator ont dépassé mes attentes.", name: 'Membre de Breaking Accelerator' },
          { quote: "C'est là où tu trouves toutes les informations, tous les outils. Ça m'a permis d'être dans le réel et de passer à l'action. Et après, tout a suivi.", name: 'Phouthone' },
          { quote: "J'ai bossé par rapport aux modules et j'ai eu la réponse d'une compagnie avec laquelle je voulais bosser depuis des années.", name: 'Membre de Breaking Accelerator' },
          { quote: "Les informations de Breaking Accelerator ont fait en sorte que j'obtienne ma stabilité financière.", name: 'Axel' },
          { quote: "On sent le travail et l'envie de bien transmettre. Merci pour la qualité de ce que tu proposes.", name: 'Membre de Breaking Accelerator' },
          { quote: "Merci à Junior. Il y a eu un gros suivi, il était derrière moi. J'ai pu définir tous mes objectifs et les accomplir. Il y a un vrai avant-après.", name: 'Mario' },
          { quote: "Je kiffe ce que je fais, c'est incroyable. Merci à toi Junior.", name: 'Membre de Breaking Accelerator' },
          { quote: "Le module masterclass est vraiment génial.", name: 'Membre de Breaking Accelerator' },
          { quote: "Ça se passe super bien, je suis épanoui, je kiffe !", name: 'Membre de Breaking Accelerator' },
        ]).map(({ quote, name }) => (
          <div class="w-[240px] md:w-[400px] flex-shrink-0 px-3 md:px-4">
            <div class="border-t border-stone-300 pt-6 h-full">
              <p class="text-sm md:text-lg text-stone-800 leading-relaxed mb-3 md:mb-4" style="font-family: 'DM Serif Display', serif;">"{quote}"</p>
              <p class="text-sm font-medium text-stone-900">{name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
    </div>
  </section>

  <script>
    (function() {
      const track = document.getElementById('testimonial-track');
      const prev = document.getElementById('testimonial-prev');
      const next = document.getElementById('testimonial-next');
      if (!track) return;

      let offset = 0;

      function getCardWidth() {
        const card = track.querySelector(':scope > div');
        return card ? card.offsetWidth : 400;
      }

      function jump(direction) {
        const cardWidth = getCardWidth();
        offset += direction * cardWidth;
        track.style.setProperty('--manual-offset', offset + 'px');
      }

      prev?.addEventListener('click', () => jump(1));
      next?.addEventListener('click', () => jump(-1));
    })();
  </script>

  <!-- LE JOURNAL -->
  <section id="journal" class="py-24 px-6 md:px-12 bg-[#F5F3EF] border-t border-stone-200">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
        <div>
          <span class="text-xs text-stone-500 uppercase tracking-widest font-medium block mb-4">Journal</span>
          <h3 class="text-3xl md:text-4xl text-stone-900 tracking-tight">Construire une carrière dans le breaking</h3>
        </div>
        <a href="/journal" class="text-stone-900 border-b border-stone-900 pb-1 hover:opacity-60 transition-opacity text-sm font-medium">Tous les articles</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { href: '/journal/pourquoi-le-niveau-ne-suffit-pas', cat: 'Comprendre son écosystème', title: 'Pourquoi le niveau ne suffit pas pour vivre du breaking' },
          { href: '/journal/ton-entourage-a-peur-pour-toi-pas-contre-toi', cat: 'Mindset', title: 'Ton entourage a peur pour toi, pas contre toi' },
          { href: '/journal/etre-paye-ca-veut-dire-apporter-de-la-valeur', cat: 'Comprendre son écosystème', title: 'Être payé, ça veut dire apporter de la valeur' },
        ].map(({ href, cat, title }) => (
          <a href={href} class="group block border-t border-stone-300 pt-6">
            <span class="text-xs text-stone-500 uppercase tracking-widest font-medium block mb-4">{cat}</span>
            <h5 class="text-2xl text-stone-900 mb-4 tracking-tight group-hover:text-stone-600 transition-colors" style="font-family: 'DM Serif Display', serif;">{title}</h5>
            <span class="inline-flex items-center text-sm font-semibold uppercase tracking-wider text-stone-900">
              Lire <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5" class="ml-2 group-hover:translate-x-1 transition-transform"></iconify-icon>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="py-20 px-6 md:px-12 bg-[#1C1C1C] text-[#F5F3EF]">
    <div class="max-w-2xl mx-auto text-center">
      <span class="text-xs text-stone-400 uppercase tracking-widest font-medium">Newsletter</span>
      <p class="text-lg md:text-xl text-stone-300 font-light leading-relaxed mt-4 mb-8">Des conseils pratiques pour construire ta carrière dans le breaking, dans ta boîte mail</p>
      <form id="newsletter-form" class="flex flex-col gap-3 max-w-md mx-auto">
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="text"
            id="newsletter-prenom"
            placeholder="Ton prénom"
            class="flex-1 px-5 py-3 rounded-full bg-stone-800 border border-stone-700 text-[#F5F3EF] placeholder-stone-500 focus:outline-none focus:border-stone-500 text-sm"
          />
          <input
            type="email"
            id="newsletter-email"
            placeholder="ton@email.com"
            required
            class="flex-1 px-5 py-3 rounded-full bg-stone-800 border border-stone-700 text-[#F5F3EF] placeholder-stone-500 focus:outline-none focus:border-stone-500 text-sm"
          />
        </div>
        <button type="submit" id="newsletter-btn" class="w-full sm:w-auto sm:self-center px-8 py-3 bg-[#F5F3EF] text-stone-900 rounded-full font-medium hover:bg-stone-300 transition-colors text-sm">
          S'inscrire
        </button>
        <p id="newsletter-msg" class="text-sm text-center hidden"></p>
      </form>
      <script>
        const form = document.getElementById('newsletter-form');
        const btn = document.getElementById('newsletter-btn');
        const msg = document.getElementById('newsletter-msg');

        form?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = (document.getElementById('newsletter-email') as HTMLInputElement).value.trim();
          const prenom = (document.getElementById('newsletter-prenom') as HTMLInputElement).value.trim();

          btn.textContent = 'Inscription…';
          btn.setAttribute('disabled', 'true');
          msg.classList.add('hidden');

          try {
            const res = await fetch('https://hook.eu1.make.com/j8wt8s7jlxc0t67wcu30bj6v3gn7xa7k', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email, prenom }),
            });
            if (res.ok) {
              form.innerHTML = '<p class="text-stone-300 text-center">Inscription confirmée. À très vite.</p>';
            } else {
              msg.textContent = 'Une erreur est survenue.';
              msg.classList.remove('hidden');
              msg.style.color = '#fca5a5';
              btn.textContent = "S'inscrire";
              btn.removeAttribute('disabled');
            }
          } catch {
            msg.textContent = 'Erreur réseau. Réessaie dans un instant.';
            msg.classList.remove('hidden');
            msg.style.color = '#fca5a5';
            btn.textContent = "S'inscrire";
            btn.removeAttribute('disabled');
          }
        });
      </script>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#1C1C1C] text-[#F5F3EF] pt-16 pb-8 px-6 md:px-12 border-t border-stone-800">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12 pb-12 border-b border-stone-800">

      <div class="space-y-4 md:w-1/3">
        <a href="/" class="text-xl tracking-tight" style="font-family: 'DM Serif Display', serif;">Breaking Accelerator</a>
        <p class="text-stone-400 text-sm leading-relaxed">
          L'accompagnement pour construire une carrière dans le breaking
        </p>
        <div class="flex space-x-3 pt-1">
          <a href="https://www.instagram.com/breaking_accelerator/" target="_blank" rel="noopener" class="w-9 h-9 border border-stone-700 rounded-full flex items-center justify-center hover:bg-[#F5F3EF] hover:text-stone-900 transition-colors">
            <iconify-icon icon="mdi:instagram" class="text-base"></iconify-icon>
          </a>
        </div>
      </div>

      <div class="space-y-4">
        <ul class="space-y-3 text-sm text-stone-400">
          <li><a href="/" class="hover:text-white transition-colors">Accueil</a></li>
          <li><a href="/a-propos" class="hover:text-white transition-colors">À propos</a></li>
          <li><a href="/journal" class="hover:text-white transition-colors">Le Journal</a></li>
          <li><a href={LP_URL} class="hover:text-white transition-colors">Rejoindre</a></li>
          <li>
            <a href="mailto:breakingaccelerator@gmail.com" class="hover:text-white transition-colors">breakingaccelerator@gmail.com</a>
          </li>
        </ul>
      </div>

      <div class="space-y-3 text-sm text-stone-400">
        <a href={LP_URL} class="inline-block px-6 py-3 bg-[#F5F3EF] text-stone-900 rounded-full text-sm font-medium hover:bg-stone-300 transition-colors">
          Rejoindre Breaking Accelerator
        </a>
      </div>

    </div>
    <div class="max-w-7xl mx-auto pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-stone-600">
      <p>© 2026 Breaking Accelerator. Tous droits réservés.</p>
      <div class="flex space-x-6 mt-4 md:mt-0">
        <a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a>
        <a href="/cgv" class="hover:text-white transition-colors">Conditions générales de vente</a>
        <a href="/confidentialite" class="hover:text-white transition-colors">Politique de confidentialité</a>
      </div>
    </div>
  </footer>

  <!-- MOBILE MENU SCRIPT -->
  <script>
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const close = document.getElementById('menu-close');

    toggle?.addEventListener('click', () => {
      if (menu?.classList.contains('hidden')) {
        menu?.classList.remove('hidden');
        menu?.classList.add('flex');
      } else {
        menu?.classList.add('hidden');
        menu?.classList.remove('flex');
      }
    });

    close?.addEventListener('click', () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
    });

    menu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu?.classList.add('hidden');
        menu?.classList.remove('flex');
      });
    });
  </script>

</Layout>
