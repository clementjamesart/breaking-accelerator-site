    </div>

    <img class="ba-logo" src="/images/ba-logo.png" alt="Breaking Accelerator" />

    <div class="legal-links">
      <a href="/cgv">Conditions générales de vente</a>
      <a href="/confidentialite">Politique de confidentialité</a>
      <a href="/mentions-legales">Mentions légales</a>
    </div>
  </div>

  <!-- Plyr JS -->
  <script is:inline src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>

  <script define:vars={{ CTA_DELAY_SECONDS, BOOKING_URL, TRACKING_URL, VSL_VIDEO_URL }}>
    // Lead identity from URL params (set by optin redirect)
    var params = new URLSearchParams(window.location.search);
    var email = params.get('email') || '';
    var utm_source = params.get('utm_source') || '';
    var utm_campaign = params.get('utm_campaign') || '';
    var utm_content = params.get('utm_content') || '';
    var device = /Mobi|Android/i.test(navigator.userAgent) ? 'mobile' : 'desktop';

    // Init Plyr
    var player = new Plyr('#vsl-player', {
      controls: [],
      clickToPlay: true,
      muted: true,
      keyboard: { focused: false, global: false },
    });

    // Shadow sur le player Plyr (bypass Astro CSS scoping)
    var plyrEl = document.querySelector('.plyr');
    if (plyrEl) plyrEl.style.boxShadow = '0 4px 30px rgba(0, 0, 0, 0.3)';

    var unmuteOverlay = document.getElementById('unmute-overlay');

    // Afficher l'overlay immédiatement (style direct pour bypass Astro CSS scoping)
    unmuteOverlay.style.display = 'flex';

    // Si la vidéo n'a pas démarré (Plyr override autoplay), relancer
    setTimeout(function() {
      if (player.paused) {
        player.muted = true;
        var p = player.play();
        if (p && p.catch) p.catch(function() {});
      }
    }, 500);

    // Click overlay pour activer le son
    unmuteOverlay.addEventListener('click', function() {
      player.muted = false;
      player.volume = 1;
      if (player.paused) player.play();
      unmuteOverlay.style.display = 'none';
    });

    // Tracking state
    var milestones = { 25: false, 50: false, 75: false, 100: false };
    var totalWatchTime = 0;
    var lastTimeUpdate = 0;

    function sendEvent(eventType, extra) {
      var payload = {
        event_type: eventType,
        email: email,
        page: '/presentation',
        utm_source: utm_source,
        utm_campaign: utm_campaign,
        utm_content: utm_content,
        device: device,
        duration_seconds: Math.round(player.currentTime || 0),
        metadata: JSON.stringify(Object.assign({
          total_watch_time: Math.round(totalWatchTime),
          video_duration: Math.round(player.duration || 0),
        }, extra || {})),
      };
      navigator.sendBeacon(TRACKING_URL, JSON.stringify(payload));
    }

    player.on('play', function() { sendEvent('vsl_start'); });
    player.on('pause', function() { sendEvent('vsl_pause'); });

    player.on('timeupdate', function() {
      var current = player.currentTime;
      var duration = player.duration;
      if (!duration) return;

      // Accumulate watch time
      if (lastTimeUpdate > 0) {
        var delta = current - lastTimeUpdate;
        if (delta > 0 && delta < 2) totalWatchTime += delta;
      }
      lastTimeUpdate = current;

      var pct = (current / duration) * 100;
      [25, 50, 75, 100].forEach(function(m) {
        if (pct >= m && !milestones[m]) {
          milestones[m] = true;
          sendEvent('vsl_' + m, { milestone: m });
        }
      });
    });

    player.on('ended', function() {
      if (!milestones[100]) {
        milestones[100] = true;
        sendEvent('vsl_100', { milestone: 100 });
      }
    });

    // Track drop-off on page leave
    window.addEventListener('beforeunload', function() {
      var pct = player.duration ? Math.round((player.currentTime / player.duration) * 100) : 0;
      sendEvent('vsl_drop', { drop_pct: pct });
    });

    // CTA timer (1460 secondes comme sur Systeme.io)
    setTimeout(function() {
      document.getElementById('cta-booking').classList.add('visible');
    }, CTA_DELAY_SECONDS * 1000);

    // UTM passthrough to booking URL
    var bookingLink = document.getElementById('booking-link');
    var utmParams = new URLSearchParams();
    ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content'].forEach(function(k) {
      var v = params.get(k);
      if (v) utmParams.set(k, v);
    });
    if (utmParams.toString()) {
      var sep = BOOKING_URL.includes('?') ? '&' : '?';
      bookingLink.href = BOOKING_URL + sep + utmParams.toString();
    }

    // Track booking click
    bookingLink.addEventListener('click', function() {
      if (typeof fbq === 'function') {
        fbq('track', 'Schedule', { content_name: 'booking_ba' });
      }
    });
  </script>

</body>
</html>
