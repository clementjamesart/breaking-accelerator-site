  </div>

  <!-- VIDEO -->
  <div class="video-wrapper">
    <video id="vsl-player" playsinline muted autoplay>
      <source src={VSL_VIDEO_URL} type="video/mp4" />
    </video>
    <div class="unmute-overlay" id="unmute-overlay">
      <span>Clique pour activer le son</span>
    </div>
  </div>

  <!-- CTA BOOKING (apparait après 1460 secondes) -->
