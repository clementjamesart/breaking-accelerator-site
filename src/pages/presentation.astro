    <a href={BOOKING_URL} class="cta-btn" id="booking-link">
      Je réserve mon appel (gratuit)
      <small>Clique ici</small>
    </a>
  </div>

  <!-- FOOTER -->
  <div class="footer-section">
    <div class="disclaimers">
