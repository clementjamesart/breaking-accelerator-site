  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #FFFFFF;
      color: #000000;
    }

    :root {
      --plyr-color-main: #008EFF;
      --plyr-video-background: #000000;
      --plyr-menu-background: #1C1C1C;
      --plyr-menu-color: #FFFFFF;
      --plyr-control-color: #FFFFFF;
      --plyr-control-spacing: 14px;
    }

    /* TOPBAR */
    .topbar {
      background: #000000;
      color: #FFFFFF;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 24px;
      font-size: 12px;
      font-weight: 700;
    }
    @media (max-width: 600px) {
      .topbar {
        flex-direction: column;
        gap: 4px;
        text-align: center;
      }
    }

    /* HERO */
    .hero {
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 24px 24px;
      text-align: center;
    }
    .hero .subtitle {
      font-size: 18px;
      font-weight: 400;
      margin-bottom: 12px;
    }
    .hero .title {
      font-size: 22px;
      font-weight: 700;
      text-transform: uppercase;
      line-height: 1.3;
      margin-bottom: 12px;
    }
    .hero .sub {
      font-size: 18px;
      font-weight: 400;
      margin-bottom: 32px;
    }

    @media (max-width: 600px) {
      .hero .subtitle { font-size: 16px; }
      .hero .title { font-size: 13px; }
      .hero .sub { font-size: 16px; }
    }

    /* VIDEO */
    .video-wrapper {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 24px 32px;
      position: relative;
    }
    /* Overlay unmute */
    .unmute-overlay {
      display: none;
      position: absolute;
      inset: 0;
      z-index: 10;
      cursor: pointer;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.3);
    }
    .unmute-overlay span {
      background: rgba(0, 0, 0, 0.7);
      color: #FFFFFF;
      font-family: 'Poppins', sans-serif;
      font-size: 16px;
      font-weight: 600;
      padding: 12px 24px;
      border-radius: 8px;
    }

    /* CTA BOOKING */
    .cta-booking {
      text-align: center;
      padding: 24px;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.5s, transform 0.5s;
      pointer-events: none;
    }
    .cta-booking.visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
    .cta-booking .cta-btn {
      display: inline-block;
      background: #0174C7;
      color: #FFFFFF;
      font-family: 'Poppins', sans-serif;
      font-size: 20px;
      font-weight: 600;
      padding: 4px 30px;
      border: 2px solid #FFFFFF;
      border-radius: 8px;
      text-decoration: none;
      line-height: 1.6;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
      transition: transform 0.2s, background-color 0.2s, box-shadow 0.2s;
    }
    .cta-booking .cta-btn:hover {
      transform: scale(1.05);
      background: #28a745;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5);
    }
    .cta-booking .cta-btn small {
      display: block;
      font-size: 14px;
      font-weight: 400;
    }

    /* FOOTER */
    .footer-section {
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 24px;
    }
    .disclaimers {
      font-family: 'Times New Roman', Times, serif;
      font-size: 9px;
      font-style: italic;
      color: #000000;
      text-align: center;
      line-height: 1.6;
    }
    .disclaimers p {
      margin-bottom: 8px;
    }
    .ba-logo {
      display: block;
      width: 120px;
      height: 120px;
      margin: 24px auto;
    }
    .legal-links {
      display: flex;
      gap: 24px;
      justify-content: center;
      margin-top: 16px;
      font-size: 12px;
    }
    .legal-links a {
      color: #0174C7;
      text-decoration: underline;
    }
  </style>
</head>
<body>

  <!-- TOPBAR -->
  <div class="topbar">
    <span>Message important pour les breakers</span>
    <span>De la part de Bboy Junior ayant + de 25 ans de carrière</span>
  </div>

  <!-- HERO -->
  <div class="hero">
    <p class="subtitle">Révélé dans ce documentaire gratuit par Bboy Junior :</p>
