---
import Layout from '../../layouts/Layout.astro';

const LP_URL = '/lpa';

const articles = [
  { slug: 'pourquoi-le-niveau-ne-suffit-pas', cat: 'Écosystème', title: 'Pourquoi le niveau ne suffit pas pour vivre du breaking', excerpt: "Il y a une croyance dans le breaking qui est rarement remise en question : deviens bon, gagne des battles, et les contrats suivront.", readTime: 8 },
  { slug: 'ton-entourage-a-peur-pour-toi-pas-contre-toi', cat: 'Mindset', title: 'Ton entourage a peur pour toi, pas contre toi', excerpt: "La majorité des danseurs qui vivent de leur art aujourd'hui sont passés exactement par là. Pas de soutien au départ. Parfois même rejetés.", readTime: 6 },
  { slug: 'etre-paye-ca-veut-dire-apporter-de-la-valeur', cat: 'Écosystème', title: 'Être payé, ça veut dire apporter de la valeur', excerpt: "Quand une marque te recrute, elle ne te fait pas une faveur. Elle a un besoin. Toi, tu y réponds. Elle, elle te rétribue.", readTime: 5 },
];

const categories = [...new Set(articles.map(a => a.cat))];
---

<Layout title="Le Journal | Breaking Accelerator" description="Construire une carrière dans le breaking.">

  <!-- BANNER -->
  <div class="bg-[#1C1C1C] text-[#F5F3EF] text-xs font-bold py-3 text-center tracking-widest uppercase px-4">
    Quand la passion devient une carrière
  </div>

  <!-- NAV -->
  <nav class="sticky top-0 z-50 w-full px-6 py-5 flex justify-between items-center bg-[#F5F3EF]/90 backdrop-blur-sm border-b border-stone-200/50">
    <a href="/" class="text-xl md:text-2xl tracking-tight text-stone-900 leading-none" style="font-family: 'DM Serif Display', serif;">
      Breaking Accelerator
    </a>
    <div class="hidden md:flex items-center space-x-8 text-sm font-medium tracking-wide text-stone-600">
      <a href="/" class="hover:text-stone-900 transition-colors">Accueil</a>
      <a href="/a-propos" class="hover:text-stone-900 transition-colors">À propos</a>
      <a href="/journal" class="text-stone-900 transition-colors">Le Journal</a>
      <a href={LP_URL} class="hover:text-stone-900 transition-colors">Rejoindre</a>
    </div>
    <button id="menu-toggle" class="md:hidden text-2xl">
      <iconify-icon icon="solar:hamburger-menu-linear" stroke-width="1.5"></iconify-icon>
    </button>
  </nav>

  <!-- MOBILE MENU -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-40 bg-[#F5F3EF] flex flex-col items-center justify-center space-y-8 text-2xl font-medium text-stone-900">
    <button id="menu-close" class="absolute top-6 right-6 text-3xl">
      <iconify-icon icon="solar:close-linear" stroke-width="1.5"></iconify-icon>
    </button>
    <a href="/" class="hover:text-stone-500 transition-colors">Accueil</a>
    <a href="/a-propos" class="hover:text-stone-500 transition-colors">À propos</a>
    <a href="/journal" class="text-stone-500 transition-colors">Le Journal</a>
    <a href={LP_URL} class="hover:text-stone-500 transition-colors">Rejoindre</a>
  </div>

  <!-- HEADER -->
  <header class="py-16 md:py-20 px-6 md:px-12 text-center">
    <div class="max-w-3xl mx-auto space-y-4">
      <span class="text-xs text-stone-500 uppercase tracking-widest font-medium">Journal</span>
      <h1 class="text-3xl md:text-4xl text-stone-900 tracking-tight" style="font-family: 'DM Serif Display', serif;">Construire une carrière dans le breaking</h1>
      <p class="text-stone-500 font-light text-lg max-w-xl mx-auto">{articles.length} articles pour passer de la passion au métier.</p>
    </div>
  </header>

  <!-- SEARCH + FILTERS -->
  <section class="px-6 md:px-12 pb-8">
    <div class="max-w-5xl mx-auto space-y-5">
      <!-- Search bar -->
      <div class="max-w-md mx-auto relative">
        <iconify-icon icon="solar:magnifer-linear" class="absolute left-4 top-1/2 -translate-y-1/2 text-stone-400 text-lg"></iconify-icon>
        <input type="text" id="journal-search" placeholder="Rechercher un article..." class="w-full pl-11 pr-4 py-3 bg-white border border-stone-200 rounded-full text-sm text-stone-900 placeholder:text-stone-400 focus:outline-none focus:border-stone-400 transition-colors" />
      </div>
      <!-- Category filters -->
      <div class="flex flex-wrap justify-center gap-2">
        <button class="journal-filter active px-4 py-1.5 text-xs font-medium tracking-wide uppercase rounded-full border border-stone-300 bg-[#1C1C1C] text-white transition-colors" data-cat="all">Tous</button>
        {categories.map(cat => (
          <button class="journal-filter px-4 py-1.5 text-xs font-medium tracking-wide uppercase rounded-full border border-stone-300 text-stone-600 hover:bg-stone-100 transition-colors" data-cat={cat}>{cat}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- ARTICLES GRID -->
  <section class="px-6 md:px-12 pb-24">
    <div id="articles-grid" class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles.map(({ slug, cat, title, excerpt, readTime }) => (
        <a href={`/journal/${slug}`} class="journal-card group flex flex-col bg-white border border-stone-200 rounded-2xl p-6 hover:shadow-lg hover:border-stone-300 transition-all duration-200" data-cat={cat} data-title={title.toLowerCase()} data-excerpt={excerpt.toLowerCase()}>
          <div class="flex items-center justify-between mb-4">
            <span class="text-[10px] font-bold uppercase tracking-widest text-stone-500 bg-stone-100 px-3 py-1 rounded-full">{cat}</span>
          </div>
          <h2 class="text-lg font-bold text-stone-900 leading-snug mb-3 group-hover:text-stone-600 transition-colors" style="font-family: 'DM Serif Display', serif;">{title}</h2>
          <p class="text-stone-500 text-sm font-light leading-relaxed mb-5 flex-1">{excerpt}</p>
          <div class="flex items-center justify-between pt-4 border-t border-stone-100">
            <span class="inline-flex items-center text-stone-400 text-xs">
              <iconify-icon icon="solar:clock-circle-linear" class="mr-1.5 text-sm"></iconify-icon>
              {readTime} min de lecture
            </span>
            <span class="inline-flex items-center text-xs font-semibold uppercase tracking-wider text-stone-900 group-hover:text-stone-600 transition-colors">
              Lire <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5" class="ml-1 group-hover:translate-x-1 transition-transform text-sm"></iconify-icon>
            </span>
          </div>
        </a>
      ))}
    </div>
    <!-- Empty state -->
    <p id="no-results" class="hidden max-w-5xl mx-auto text-center text-stone-400 py-12 text-sm">Aucun article trouvé.</p>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#1C1C1C] text-[#F5F3EF] pt-16 pb-8 px-6 md:px-12 border-t border-stone-800">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12 pb-12 border-b border-stone-800">
      <div class="space-y-4 md:w-1/3">
        <a href="/" class="text-xl tracking-tight" style="font-family: 'DM Serif Display', serif;">Breaking Accelerator</a>
        <p class="text-stone-400 text-sm leading-relaxed">
          L'accompagnement pour construire une carrière dans le breaking
        </p>
        <div class="flex space-x-3 pt-1">
          <a href="https://www.instagram.com/breaking_accelerator/" target="_blank" rel="noopener" class="w-9 h-9 border border-stone-700 rounded-full flex items-center justify-center hover:bg-[#F5F3EF] hover:text-stone-900 transition-colors">
            <iconify-icon icon="mdi:instagram" class="text-base"></iconify-icon>
          </a>
        </div>
      </div>
      <div class="space-y-4">
        <ul class="space-y-3 text-sm text-stone-400">
          <li><a href="/" class="hover:text-white transition-colors">Accueil</a></li>
          <li><a href="/a-propos" class="hover:text-white transition-colors">À propos</a></li>
          <li><a href="/journal" class="hover:text-white transition-colors">Le Journal</a></li>
          <li><a href={LP_URL} class="hover:text-white transition-colors">Rejoindre</a></li>
          <li>
          <li>
            <a href="mailto:breakingaccelerator@gmail.com" class="hover:text-white transition-colors">breakingaccelerator@gmail.com</a>
          </li>
        </ul>
      </div>
      <div class="space-y-3 text-sm text-stone-400">
        <a href={LP_URL} class="inline-block px-6 py-3 bg-[#F5F3EF] text-stone-900 rounded-full text-sm font-medium hover:bg-stone-300 transition-colors">
          Rejoindre Breaking Accelerator
        </a>
      </div>
    </div>
    <div class="max-w-7xl mx-auto pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-stone-600">
      <p>© 2026 Breaking Accelerator. Tous droits réservés.</p>
      <div class="flex space-x-6 mt-4 md:mt-0">
        <a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a>
        <a href="/cgv" class="hover:text-white transition-colors">Conditions générales de vente</a>
        <a href="/confidentialite" class="hover:text-white transition-colors">Politique de confidentialité</a>
      </div>
    </div>
  </footer>

  <!-- SCRIPTS -->
  <script>
    // Mobile menu
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const close = document.getElementById('menu-close');

    toggle?.addEventListener('click', () => {
      if (menu?.classList.contains('hidden')) {
        menu?.classList.remove('hidden');
        menu?.classList.add('flex');
      } else {
        menu?.classList.add('hidden');
        menu?.classList.remove('flex');
      }
    });

    close?.addEventListener('click', () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
    });

    menu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu?.classList.add('hidden');
        menu?.classList.remove('flex');
      });
    });

    // Search + filter
    const searchInput = document.getElementById('journal-search') as HTMLInputElement;
    const cards = document.querySelectorAll('.journal-card') as NodeListOf<HTMLElement>;
    const filterBtns = document.querySelectorAll('.journal-filter') as NodeListOf<HTMLButtonElement>;
    const noResults = document.getElementById('no-results');
    let activeCat = 'all';

    function filterCards() {
      const query = searchInput?.value.toLowerCase().trim() || '';
      let visible = 0;
      cards.forEach(card => {
        const cat = card.dataset.cat || '';
        const title = card.dataset.title || '';
        const excerpt = card.dataset.excerpt || '';
        const matchesCat = activeCat === 'all' || cat === activeCat;
        const matchesSearch = !query || title.includes(query) || excerpt.includes(query);
        if (matchesCat && matchesSearch) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    }

    searchInput?.addEventListener('input', filterCards);

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => {
          b.classList.remove('active', 'bg-[#1C1C1C]', 'text-white');
          b.classList.add('text-stone-600');
        });
        btn.classList.add('active', 'bg-[#1C1C1C]', 'text-white');
        btn.classList.remove('text-stone-600');
        activeCat = btn.dataset.cat || 'all';
        filterCards();
      });
    });
  </script>

</Layout>
