---
const WEBHOOK_URL = 'https://automate.dancingaccelerator.com/webhook/optin-ba';
const VSL_URL = '/presentation';
const META_PIXEL_ID = '1525345608489094';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Breaking Accelerator | Candidature</title>
  <meta name="description" content="Découvre comment faire carrière et vivre de ta passion pour le break. Validé par Bboy Junior." />

  <!-- Meta Pixel Code -->
  <script>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window,document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1525345608489094');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1525345608489094&ev=PageView&noscript=1" /></noscript>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    body {
      font-family: 'Manrope', sans-serif;
      background-color: #0D0D0D;
      color: #F5F3EF;
      margin: 0;
    }
    h1, h2, h3 { font-family: 'DM Serif Display', serif; }

    .topbar {
      background: #1C1C1C;
      text-align: center;
      padding: 12px 16px;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      line-height: 1.4;
    }

    .hero {
      max-width: 720px;
      margin: 0 auto;
      padding: 48px 24px 32px;
      text-align: center;
    }
    .hero .subtitle {
      font-size: 16px;
      color: #A8A29E;
      margin-bottom: 16px;
    }
    .hero h1 {
      font-size: clamp(28px, 5vw, 42px);
      line-height: 1.15;
      margin: 0 0 20px;
      font-weight: 400;
    }
    .hero .validated {
      font-size: 14px;
      color: #78716C;
      margin-top: 8px;
    }

    .cta-section {
      text-align: center;
      padding: 24px;
    }
    .cta-btn {
      display: inline-block;
      background: #F5F3EF;
      color: #0D0D0D;
      font-family: 'Manrope', sans-serif;
      font-size: 16px;
      font-weight: 700;
      padding: 16px 48px;
      border: none;
      cursor: pointer;
      letter-spacing: 0.02em;
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .cta-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 20px rgba(245, 243, 239, 0.15);
    }
    .cta-btn small {
      display: block;
      font-size: 12px;
      font-weight: 400;
      margin-top: 4px;
      color: #57534E;
    }

    /* Popup overlay */
    .overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      z-index: 100;
      align-items: center;
      justify-content: center;
    }
    .overlay.active { display: flex; }

    .popup {
      background: #1C1C1C;
      padding: 40px 32px;
      max-width: 420px;
      width: 90%;
      position: relative;
    }
    .popup-close {
      position: absolute;
      top: 12px;
      right: 16px;
      background: none;
      border: none;
      color: #78716C;
      font-size: 24px;
      cursor: pointer;
    }
    .popup h2 {
      font-size: 18px;
      font-weight: 400;
      line-height: 1.4;
      margin: 0 0 24px;
      text-align: center;
    }
    .popup input {
      display: block;
      width: 100%;
      padding: 14px 16px;
      margin-bottom: 12px;
      background: #0D0D0D;
      border: 1px solid #292524;
      color: #F5F3EF;
      font-family: 'Manrope', sans-serif;
      font-size: 15px;
      box-sizing: border-box;
    }
    .popup input::placeholder { color: #57534E; }
    .popup input:focus {
      outline: none;
      border-color: #F5F3EF;
    }
    .popup .submit-btn {
      display: block;
      width: 100%;
      background: #F5F3EF;
      color: #0D0D0D;
      font-family: 'Manrope', sans-serif;
      font-size: 15px;
      font-weight: 700;
      padding: 16px;
      border: none;
      cursor: pointer;
      margin-top: 4px;
      transition: opacity 0.15s;
    }
    .popup .submit-btn:hover { opacity: 0.9; }
    .popup .submit-btn:disabled {
      opacity: 0.5;
      cursor: wait;
    }
    .popup .submit-btn small {
      display: block;
      font-size: 11px;
      font-weight: 400;
      margin-top: 4px;
      color: #57534E;
    }
    .popup .disclaimer {
      font-size: 11px;
      color: #57534E;
      text-align: center;
      margin-top: 16px;
      line-height: 1.5;
    }
    .popup .error-msg {
      color: #EF4444;
      font-size: 13px;
      text-align: center;
      margin-bottom: 12px;
      display: none;
    }

    footer {
      max-width: 720px;
      margin: 64px auto 0;
      padding: 32px 24px;
      border-top: 1px solid #292524;
      font-size: 11px;
      color: #57534E;
      line-height: 1.6;
      text-align: center;
    }
    footer a {
      color: #78716C;
      text-decoration: underline;
    }
    .legal-links {
      display: flex;
      gap: 24px;
      justify-content: center;
      margin-top: 24px;
      font-size: 12px;
    }
  </style>
</head>
<body>

  <!-- TOPBAR -->
  <div class="topbar">
    <div>Message important pour les breakers</div>
    <div style="margin-top:4px; color:#A8A29E; font-weight:600;">De la part de Bboy Junior ayant + de 25 ans de carriere</div>
  </div>

  <!-- HERO -->
  <div class="hero">
    <p class="subtitle">Pour les breakers qui veulent vivre de leur art des maintenant</p>
    <h1>Decouvre la candidature pour faire carriere et vivre de ta passion pour le break</h1>
    <p class="validated">Validee par Bboy Junior</p>
  </div>

  <!-- PHOTO JUNIOR -->
  <div style="max-width: 720px; margin: 0 auto; padding: 0 24px;">
    <img src="/images/junior-action.jpg" alt="Bboy Junior en action"
         style="width: 100%; aspect-ratio: 16/9; object-fit: cover;" loading="eager" />
  </div>

  <!-- CTA -->
  <div class="cta-section">
    <button class="cta-btn" id="open-popup">
      Je decouvre (gratuitement)
      <small>Clique ici</small>
    </button>
  </div>

  <!-- POPUP OPTIN -->
  <div class="overlay" id="overlay">
    <div class="popup">
      <button class="popup-close" id="close-popup">&times;</button>
      <h2>Pour le decouvrir, clique sur le bouton apres avoir renseigne tes informations :</h2>
      <div class="error-msg" id="error-msg"></div>
      <form id="optin-form" action={WEBHOOK_URL} method="POST">
        <input type="text" name="prenom" placeholder="Prenom" required />
        <input type="email" name="email" placeholder="Email" required />
        <input type="hidden" name="utm_source" id="utm_source" />
        <input type="hidden" name="utm_medium" id="utm_medium" />
        <input type="hidden" name="utm_campaign" id="utm_campaign" />
        <input type="hidden" name="utm_content" id="utm_content" />
        <button type="submit" class="submit-btn" id="submit-btn">
          Je decouvre gratuitement
        </button>
      </form>
      <p class="disclaimer">
        Tes informations sont protegees et ne seront pas partagees.
      </p>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <p>
      Nous ne pouvons pas garantir, et nous ne pretendons pas garantir, que vous obtiendrez des resultats ou gagnerez de l'argent en utilisant nos idees, nos informations, nos outils ou nos strategies.
      Les temoignages, exemples de revenus et autres resultats presentes sur ce site, bien que reels et controles, sont fournis a titre illustratif et ne constituent en aucun cas une garantie de resultats futurs.
    </p>
    <p style="margin-top:16px;">&copy; Breaking Accelerator — Tous droits reserves</p>
    <div class="legal-links">
      <a href="/mentions-legales">Mentions legales</a>
      <a href="/cgv">CGV</a>
      <a href="/confidentialite">Politique de confidentialite</a>
    </div>
  </footer>

  <script define:vars={{ WEBHOOK_URL, VSL_URL }}>
    // UTM capture
    const params = new URLSearchParams(window.location.search);
    ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content'].forEach(k => {
      const el = document.getElementById(k);
      if (el && params.get(k)) el.value = params.get(k);
    });

    // Popup
    document.getElementById('open-popup').addEventListener('click', () => {
      document.getElementById('overlay').classList.add('active');
    });
    document.getElementById('close-popup').addEventListener('click', () => {
      document.getElementById('overlay').classList.remove('active');
    });
    document.getElementById('overlay').addEventListener('click', (e) => {
      if (e.target === e.currentTarget) {
        document.getElementById('overlay').classList.remove('active');
      }
    });

    // Form submit
    document.getElementById('optin-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('submit-btn');
      const errorMsg = document.getElementById('error-msg');
      btn.disabled = true;
      btn.textContent = 'Envoi en cours...';
      errorMsg.style.display = 'none';

      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);

      try {
        const resp = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (resp.ok) {
          // Meta Pixel event
          if (typeof fbq === 'function') {
            fbq('track', 'Lead', { content_name: 'optin_ba' });
          }
          // Pass lead identity to VSL page
          const vslParams = new URLSearchParams({
            email: data.email,
            utm_source: data.utm_source || '',
            utm_medium: data.utm_medium || '',
            utm_campaign: data.utm_campaign || '',
            utm_content: data.utm_content || '',
          }).toString();
          window.location.href = VSL_URL + '?' + vslParams;
        } else {
          throw new Error('Erreur serveur');
        }
      } catch (err) {
        errorMsg.textContent = 'Une erreur est survenue. Reessaye.';
        errorMsg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Je decouvre gratuitement';
      }
    });
  </script>

</body>
</html>
