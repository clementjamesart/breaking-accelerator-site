---
import PostHog from '../components/PostHog.astro';
const WEBHOOK_URL = 'https://automate.dancingaccelerator.com/webhook/optin-ba';
const TRACKING_URL = '/api/track';
const VSL_URL = '/p-7f3a9d';
const PAGE_ID = '/lpa';
const META_PIXEL_ID = '1525345608489094';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Breaking Accelerator | Vidéo gratuite avec Bboy Junior</title>
  <meta name="description" content="Junior t'explique en 25 minutes comment construire une vraie carrière en break et vivre de ta danse. Gratuit." />
  <PostHog />

  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" as="style" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet" />

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #0a0a0a;
      color: #FFFFFF;
      line-height: 1.5;
    }

    .topbar {
      background: #d4af37;
      color: #000000;
      text-align: center;
      padding: 10px 16px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.3px;
    }

    .container {
      max-width: 680px;
      margin: 0 auto;
      padding: 32px 20px;
    }

    .hero {
      text-align: center;
      margin-bottom: 32px;
    }

    .hero .qualifier {
      font-size: 14px;
      font-weight: 600;
      color: #d4af37;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 16px;
    }

    .hero h1 {
      font-size: 28px;
      font-weight: 800;
      line-height: 1.25;
      margin-bottom: 16px;
    }

    .hero .sub {
      font-size: 17px;
      font-weight: 400;
      color: #cccccc;
      margin-bottom: 24px;
    }

    .hero .sub strong {
      color: #ffffff;
    }

    .junior-img {
      width: 180px;
      height: 180px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid #d4af37;
      margin: 0 auto 8px;
      display: block;
    }

    .junior-name {
      font-size: 14px;
      font-weight: 600;
      color: #d4af37;
      text-align: center;
      margin-bottom: 32px;
    }

    .bullets {
      margin-bottom: 32px;
      padding: 0 8px;
    }

    .bullets h2 {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 16px;
      text-align: center;
    }

    .bullet-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 14px;
      font-size: 15px;
      color: #e0e0e0;
    }

    .bullet-icon {
      flex-shrink: 0;
      width: 22px;
      height: 22px;
      background: #d4af37;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
      color: #000;
      margin-top: 2px;
    }

    .social-proof {
      text-align: center;
      padding: 20px;
      background: rgba(212, 175, 55, 0.08);
      border: 1px solid rgba(212, 175, 55, 0.2);
      border-radius: 8px;
      margin-bottom: 32px;
      font-size: 14px;
      color: #cccccc;
    }

    .social-proof strong {
      color: #ffffff;
    }

    .cta-section {
      text-align: center;
      margin-bottom: 32px;
    }

    .cta-btn {
      display: inline-block;
      background: #d4af37;
      color: #000000;
      font-family: 'Poppins', sans-serif;
      font-size: 18px;
      font-weight: 700;
      padding: 16px 32px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 20px rgba(212, 175, 55, 0.3);
    }

    .cta-btn:hover {
      transform: scale(1.03);
      box-shadow: 0 6px 25px rgba(212, 175, 55, 0.5);
    }

    .cta-btn small {
      display: block;
      font-size: 13px;
      font-weight: 400;
      margin-top: 4px;
      color: #333;
    }

    .credibility {
      text-align: center;
      font-size: 13px;
      color: #888;
      margin-bottom: 40px;
    }

    .footer-section {
      border-top: 1px solid #222;
      padding-top: 32px;
      text-align: center;
    }

    .disclaimers {
      font-size: 10px;
      color: #555;
      line-height: 1.6;
      margin-bottom: 16px;
    }

    .ba-logo {
      width: 80px;
      height: 80px;
      margin: 16px auto;
      display: block;
      opacity: 0.6;
    }

    .legal-links {
      display: flex;
      gap: 20px;
      justify-content: center;
      font-size: 11px;
    }

    .legal-links a {
      color: #666;
      text-decoration: underline;
    }

    /* POPUP */
    .overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.7);
      z-index: 100;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .overlay.active { display: flex; }

    .popup {
      background: #111111;
      padding: 32px 24px;
      max-width: 440px;
      width: 100%;
      position: relative;
      border: 1px solid #d4af37;
      border-radius: 12px;
    }

    .popup-close {
      position: absolute;
      top: 8px;
      right: 12px;
      background: none;
      border: none;
      color: #666;
      font-size: 28px;
      cursor: pointer;
      line-height: 1;
    }

    .popup h2 {
      font-size: 18px;
      font-weight: 700;
      line-height: 1.4;
      margin: 0 0 8px;
      text-align: center;
      color: #FFFFFF;
    }

    .popup .popup-sub {
      font-size: 14px;
      color: #999;
      text-align: center;
      margin-bottom: 20px;
    }

    .popup input {
      display: block;
      width: 100%;
      padding: 14px 16px;
      margin-bottom: 12px;
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 8px;
      color: #FFFFFF;
      font-family: 'Poppins', sans-serif;
      font-size: 16px;
    }
    .popup input::placeholder { color: #666; }
    .popup input:focus {
      outline: none;
      border-color: #d4af37;
    }

    .popup .submit-btn {
      display: block;
      width: 100%;
      background: #d4af37;
      color: #000000;
      font-family: 'Poppins', sans-serif;
      font-size: 17px;
      font-weight: 700;
      padding: 14px 24px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
    }
    .popup .submit-btn:hover {
      transform: scale(1.02);
      box-shadow: 0 6px 20px rgba(212, 175, 55, 0.5);
    }
    .popup .submit-btn:disabled {
      opacity: 0.5;
      cursor: wait;
    }

    .popup .disclaimer {
      font-size: 12px;
      color: #666;
      text-align: center;
      margin-top: 12px;
    }

    .popup .error-msg {
      color: #EF4444;
      font-size: 13px;
      text-align: center;
      margin-bottom: 12px;
      display: none;
    }

    @media (max-width: 600px) {
      .hero h1 { font-size: 22px; }
      .hero .sub { font-size: 15px; }
      .cta-btn { font-size: 16px; padding: 14px 24px; width: 100%; }
      .bullet-item { font-size: 14px; }
      .junior-img { width: 140px; height: 140px; }
    }
  </style>
</head>
<body>

  <div class="topbar">
    Vidéo gratuite de 25 minutes avec Bboy Junior
  </div>

  <div class="container">

    <div class="hero">
      <p class="qualifier">Pour les breakers qui veulent en vivre</p>
      <h1>Comment construire une carrière en break et vivre de ta danse</h1>
      <p class="sub">Junior t'explique en <strong>25 minutes</strong> la méthode qu'il aurait aimé connaître quand il a démarré.</p>
      <img class="junior-img" src="/images/junior-face.jpeg" alt="Bboy Junior" loading="eager" />
      <p class="junior-name">Bboy Junior — 25+ ans de carrière professionnelle</p>
    </div>

    <div class="cta-section">
      <button class="cta-btn" id="open-popup">
        Voir la vidéo gratuite
        <small>Accès immédiat</small>
      </button>
    </div>

    <div class="bullets">
      <h2>Dans cette vidéo, tu vas découvrir :</h2>
      <div class="bullet-item">
        <span class="bullet-icon">1</span>
        <span>Comment passer de "je danse le week-end" à "je vis de ma danse" sans dépendre des cours sous-payés</span>
      </div>
      <div class="bullet-item">
        <span class="bullet-icon">2</span>
        <span>L'erreur qui empêche la plupart des breakers de décrocher des contrats réguliers (et comment la corriger)</span>
      </div>
      <div class="bullet-item">
        <span class="bullet-icon">3</span>
        <span>Le plan que Junior suivrait s'il devait reconstruire sa carrière de zéro en 2026</span>
      </div>
    </div>

    <div class="social-proof">
      <strong>20 breakers</strong> suivent déjà cette méthode pour structurer leur carrière et vivre de leur passion.
    </div>

    <div class="cta-section">
      <button class="cta-btn" id="open-popup-2">
        Voir la vidéo gratuite
        <small>Accès immédiat</small>
      </button>
    </div>

    <div class="credibility">
      Bboy Junior : champion du monde, 1000+ contrats internationaux, Red Bull BC One All Star. Il a construit exactement la carrière que tu vises.
    </div>

    <div class="footer-section">
      <div class="disclaimers">
        <p>Ce site ne fait pas partie du site web de Facebook ou de Facebook Inc. En outre, ce site n'est PAS approuvé par Facebook de quelque manière que ce soit. FACEBOOK est une marque déposée de FACEBOOK, Inc.</p>
        <p>&copy; Breaking Accelerator — Tous droits réservés</p>
      </div>

      <img class="ba-logo" src="/images/ba-logo.png" alt="Breaking Accelerator" />

      <div class="legal-links">
        <a href="/cgv">CGV</a>
        <a href="/confidentialite">Confidentialité</a>
        <a href="/mentions-legales">Mentions légales</a>
      </div>
    </div>

  </div>

  <!-- POPUP OPTIN -->
  <div class="overlay" id="overlay">
    <div class="popup">
      <button class="popup-close" id="close-popup">&times;</button>
      <h2>Accède à la vidéo gratuite</h2>
      <p class="popup-sub">Entre ton prénom et ton email pour la regarder maintenant.</p>
      <div class="error-msg" id="error-msg"></div>
      <form id="optin-form">
        <input type="text" name="prenom" placeholder="Ton prénom" required />
        <input type="email" name="email" placeholder="Ton email" required />
        <input type="hidden" name="utm_source" id="utm_source" />
        <input type="hidden" name="utm_medium" id="utm_medium" />
        <input type="hidden" name="utm_campaign" id="utm_campaign" />
        <input type="hidden" name="utm_content" id="utm_content" />
        <input type="hidden" name="utm_term" id="utm_term" />
        <input type="hidden" name="ad_id" id="ad_id" />
        <input type="hidden" name="adset_id" id="adset_id" />
        <input type="hidden" name="campaign_id" id="campaign_id" />
        <input type="hidden" name="placement" id="placement" />
        <input type="hidden" name="fbclid" id="fbclid" />
        <button type="submit" class="submit-btn" id="submit-btn">
          Regarder la vidéo maintenant
        </button>
      </form>
      <p class="disclaimer">
        Tes informations restent privées. Pas de spam.
      </p>
    </div>
  </div>

  <!-- Meta Pixel (deferred) -->
  <script is:inline>
    setTimeout(function(){
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window,document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1525345608489094');
      fbq('track', 'PageView');
    }, 0);
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1525345608489094&ev=PageView&noscript=1" /></noscript>

  <!-- Microsoft Clarity (deferred) -->
  <script is:inline>
    setTimeout(function(){
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "vkvuziprou");
    }, 0);
  </script>

  <script define:vars={{ WEBHOOK_URL, TRACKING_URL, VSL_URL, PAGE_ID }}>
    // UTM + ad attribution capture
    const params = new URLSearchParams(window.location.search);
    const ATTR_KEYS = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'ad_id', 'adset_id', 'campaign_id', 'placement', 'fbclid'];
    ATTR_KEYS.forEach(function(k) {
      var el = document.getElementById(k);
      if (el && params.get(k)) el.value = params.get(k);
    });

    // LP page_view tracking (fire once on load)
    try {
      var device = /Mobi|Android/i.test(navigator.userAgent) ? 'mobile' : 'desktop';
      var pvPayload = {
        event_type: 'lp_page_view',
        email: params.get('email') || '',
        page: PAGE_ID,
        utm_source: params.get('utm_source') || '',
        utm_medium: params.get('utm_medium') || '',
        utm_campaign: params.get('utm_campaign') || '',
        utm_content: params.get('utm_content') || '',
        utm_term: params.get('utm_term') || '',
        ad_id: params.get('ad_id') || '',
        adset_id: params.get('adset_id') || '',
        campaign_id: params.get('campaign_id') || '',
        placement: params.get('placement') || '',
        fbclid: params.get('fbclid') || '',
        device: device,
        duration_seconds: 0,
        metadata: JSON.stringify({ referrer: document.referrer || '' }),
      };
      navigator.sendBeacon(TRACKING_URL, JSON.stringify(pvPayload));
      try { window.posthog && window.posthog.capture('lp_page_view', pvPayload); } catch (e) {}
    } catch (e) {}

    // Popup open (both CTA buttons)
    document.getElementById('open-popup').addEventListener('click', function() {
      document.getElementById('overlay').classList.add('active');
    });
    document.getElementById('open-popup-2').addEventListener('click', function() {
      document.getElementById('overlay').classList.add('active');
    });
    // Close popup
    document.getElementById('close-popup').addEventListener('click', function() {
      document.getElementById('overlay').classList.remove('active');
    });
    document.getElementById('overlay').addEventListener('click', function(e) {
      if (e.target === e.currentTarget) {
        document.getElementById('overlay').classList.remove('active');
      }
    });

    // Reset button if user navigates back (bfcache restore)
    window.addEventListener('pageshow', function(e) {
      if (e.persisted) {
        var btn = document.getElementById('submit-btn');
        btn.disabled = false;
        btn.textContent = 'Regarder la vidéo maintenant';
      }
    });

    // Form submit
    document.getElementById('optin-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var btn = document.getElementById('submit-btn');
      var errorMsg = document.getElementById('error-msg');
      btn.disabled = true;
      btn.textContent = 'Envoi en cours...';
      errorMsg.style.display = 'none';

      var formData = new FormData(e.target);
      var data = Object.fromEntries(formData);

      var leadId = crypto.randomUUID ? crypto.randomUUID() : 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
        var r = Math.random() * 16 | 0; return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
      });
      data.lead_id = leadId;

      // Build redirect URL (carry attribution all the way to the VSL)
      var vslParams = new URLSearchParams({
        email: data.email,
        lead_id: leadId,
        utm_source: data.utm_source || '',
        utm_medium: data.utm_medium || '',
        utm_campaign: data.utm_campaign || '',
        utm_content: data.utm_content || '',
        utm_term: data.utm_term || '',
        ad_id: data.ad_id || '',
        adset_id: data.adset_id || '',
        campaign_id: data.campaign_id || '',
        placement: data.placement || '',
        fbclid: data.fbclid || '',
      }).toString();

      // Fire webhook in background (sendBeacon survives page navigation)
      var blob = new Blob([JSON.stringify(data)], { type: 'application/json' });
      navigator.sendBeacon(WEBHOOK_URL, blob);
      navigator.sendBeacon('/api/kit-optin', blob);
      try {
        if (window.posthog) {
          if (data.email) window.posthog.identify(data.email, { email: data.email });
          window.posthog.capture('optin_submit', data);
        }
      } catch (e) {}

      // Redirect immediately
      window.location.href = VSL_URL + '?' + vslParams;
    });
  </script>

</body>
</html>
