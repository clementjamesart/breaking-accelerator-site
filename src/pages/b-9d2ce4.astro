---
import PostHog from '../components/PostHog.astro';
const CAL_LINK = 'breakingaccelerator/appel-bilan-de-carriere';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Réserver un appel | Breaking Accelerator</title>
  <meta name="robots" content="noindex, nofollow" />
  <PostHog />

  <!-- Meta Pixel Code -->
  <script>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window,document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1525345608489094');
    fbq('track', 'PageView');
    fbq('track', 'Schedule', { content_name: 'booking_ba' });
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1525345608489094&ev=PageView&noscript=1" /></noscript>

  <!-- Microsoft Clarity -->
  <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "vkvuziprou");
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet" />

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #FFFFFF;
      color: #000000;
    }

    .hero {
      max-width: 1000px;
      margin: 0 auto;
      padding: 32px 24px 16px;
      text-align: center;
    }
    .hero .title {
      font-size: 20px;
      font-weight: 700;
      line-height: 1.4;
    }

    .cal-container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 24px 40px;
    }

    .footer-section {
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 24px;
    }
    .disclaimers {
      font-family: 'Times New Roman', Times, serif;
      font-size: 9px;
      font-style: italic;
      color: #000000;
      text-align: center;
      line-height: 1.6;
    }
    .disclaimers p {
      margin-bottom: 8px;
    }
    .ba-logo {
      display: block;
      width: 120px;
      height: 120px;
      margin: 24px auto;
    }
    .legal-links {
      display: flex;
      gap: 24px;
      justify-content: center;
      margin-top: 16px;
      font-size: 12px;
    }
    .legal-links a {
      color: #0174C7;
      text-decoration: underline;
    }
  </style>
</head>
<body>

  <div class="hero">
    <p class="title">RÉSERVE TON APPEL (GRATUIT) POUR TRANSFORMER TA PASSION EN PROFESSION ⬇️</p>
  </div>

  <div class="cal-container">
    <div id="cal-inline" style="width:100%;overflow:visible;"></div>
  </div>

  <div class="footer-section">
    <div class="disclaimers">
      <p>Ce site ne fait pas partie du site web de Facebook ou de Facebook Inc. En outre, ce site n'est PAS approuvé par Facebook de quelque manière que ce soit.<br />FACEBOOK est une marque déposée de FACEBOOK, Inc.</p>
      <p>&copy; Breaking Accelerator - Tous droits réservés</p>
    </div>

    <img class="ba-logo" src="/images/ba-logo.png" alt="Breaking Accelerator" />

    <div class="legal-links">
      <a href="/cgv">Conditions générales de vente</a>
      <a href="/confidentialite">Politique de confidentialité</a>
      <a href="/mentions-legales">Mentions légales</a>
    </div>
  </div>

  <!-- Cal.com Embed -->
  <script is:inline>
    (function (C, A, L) {
      var p = function (a, ar) { a.q.push(ar); };
      var d = C.document;
      C.Cal = C.Cal || function () {
        var cal = C.Cal;
        var ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          var api = function () { p(api, arguments); };
          var namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ["initNamespace", namespace]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", { origin: "https://app.cal.com" });

    // Prefill from URL params (preserves email entered at optin)
    var urlParams = new URLSearchParams(window.location.search);
    var prefilledEmail = urlParams.get('email') || '';
    var prefilledName = urlParams.get('name') || urlParams.get('prenom') || '';

    Cal("inline", {
      elementOrSelector: "#cal-inline",
      calLink: "breakingaccelerator/appel-bilan-de-carriere",
      config: {
        layout: "month_view",
        name: prefilledName,
        email: prefilledEmail
      }
    });

    Cal("ui", {
      hideEventTypeDetails: false,
      layout: "month_view"
    });

    // Redirect vers la thank you page apres booking reussi
    Cal("on", {
      action: "bookingSuccessful",
      callback: function(e) {
        window.location.href = "/t-4e8b2f";
      }
    });
  </script>

</body>
</html>
